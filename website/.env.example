# Copier vers .env.local pour « vercel dev » (ne pas commiter)
SUPABASE_URL=https://VOTRE_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_secret

# Recommandé en production
PUBLIC_SITE_URL=https://www.openprivacy.ch
TURNSTILE_SECRET_KEY=
# Clé site Turnstile (côté navigateur) — à mettre aussi dans config.js → turnstileSiteKey

# Vérification e-mail (optionnel ; sans cela, clé affichée immédiatement)
RESEND_API_KEY=
EMAIL_FROM=OpenPrivacy <noreply@votredomaine.ch>

# Diagnostic détaillé /api/health (optionnel)
HEALTH_ADMIN_TOKEN=
